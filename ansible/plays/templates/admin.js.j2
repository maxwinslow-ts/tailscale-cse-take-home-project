  'Albania': '🇦🇱', 'Andorra': '🇦🇩', 'Austria': '🇦🇹', 'Belarus': '🇧🇾',
  'Belgium': '🇧🇪', 'Bosnia and Herzegovina': '🇧🇦', 'Bulgaria': '🇧🇬',
  'Croatia': '🇭🇷', 'Cyprus': '🇨🇾', 'Czech Republic': '🇨🇿', 'Denmark': '🇩🇰',
  'England': '🏴󠁧󠁢󠁥󠁮󠁧󠁿', 'Estonia': '🇪🇪', 'Finland': '🇫🇮', 'France': '🇫🇷',
  'Germany': '🇩🇪', 'Greece': '🇬🇷', 'Hungary': '🇭🇺', 'Iceland': '🇮🇸',
  'Ireland': '🇮🇪', 'Italy': '🇮🇹', 'Kosovo': '🇽🇰', 'Latvia': '🇱🇻',
  'Liechtenstein': '🇱🇮', 'Lithuania': '🇱🇹', 'Luxembourg': '🇱🇺',
  'Malta': '🇲🇹', 'Moldova': '🇲🇩', 'Monaco': '🇲🇨', 'Montenegro': '🇲🇪',
  'Netherlands': '🇳🇱', 'North Macedonia': '🇲🇰', 'Norway': '🇳🇴',
  'Poland': '🇵🇱', 'Portugal': '🇵🇹', 'Romania': '🇷🇴', 'Russia': '🇷🇺',
  'San Marino': '🇸🇲', 'Scotland': '🏴󠁧󠁢󠁳󠁣󠁴󠁿', 'Serbia': '🇷🇸',
  'Slovakia': '🇸🇰', 'Slovenia': '🇸🇮', 'Spain': '🇪🇸', 'Sweden': '🇸🇪',
  'Switzerland': '🇨🇭', 'Ukraine': '🇺🇦', 'Wales': '🏴󠁧󠁢󠁷󠁬󠁳󠁿',
};

function queryEuropeans() {
  const raw = execSync(
    'mysql -h ' + DB_IP + ' -u appadmin -padminpass -D app --skip-ssl --default-character-set=utf8mb4 ' +
    '-e "SELECT FirstName, LastName, Flag, CountryOfOrigin FROM famous_europeans ORDER BY RAND() LIMIT 3" ' +
    '--batch --raw 2>/dev/null',
    { timeout: 10000, encoding: 'utf8' }
  );
  const lines = raw.trim().split('\n');
  const headers = lines[0].split('\t');
  return lines.slice(1).map(l => {
    const v = l.split('\t');
    return Object.fromEntries(headers.map((h, i) => [h, v[i]]));
  });
}

function insertEuropean(firstName, lastName, country) {
  const flag = COUNTRIES[country];
  if (!flag) throw new Error('Unknown country: ' + country);
  if (!firstName || !lastName) throw new Error('First name and last name are required');
  // Escape single quotes to prevent SQL injection
  const esc = s => s.replace(/'/g, "''").replace(/\\/g, '\\\\');
  const sql = "INSERT INTO famous_europeans (FirstName, LastName, CountryOfOrigin, Flag) VALUES ('" +
    esc(firstName) + "', '" + esc(lastName) + "', '" + esc(country) + "', '" + flag + "')";
  execSync(
    'mysql -h ' + DB_IP + ' -u appadmin -padminpass -D app --skip-ssl --default-character-set=utf8mb4 ' +
    '-e ' + JSON.stringify(sql) + ' 2>&1',
    { timeout: 10000, encoding: 'utf8' }
  );
}

function parseBody(req) {
  return new Promise((resolve, reject) => {
    let body = '';
    req.on('data', c => { body += c; if (body.length > 4096) reject(new Error('Body too large')); });
    req.on('end', () => resolve(body));
  });
}

function countryOptions() {
  return Object.keys(COUNTRIES).sort().map(c =>
    '            <option value="' + c + '">' + COUNTRIES[c] + ' ' + c + '</option>'
  ).join('\n');
}

