const server = http.createServer(async (req, res) => {
  // ── POST /add — insert a new European ──
  if (req.method === 'POST' && req.url === '/add') {
    try {
      const body = await parseBody(req);
      const params = new URLSearchParams(body);
      const firstName = (params.get('firstName') || '').trim();
      const lastName = (params.get('lastName') || '').trim();
      const country = (params.get('country') || '').trim();
      insertEuropean(firstName, lastName, country);
      res.writeHead(302, { Location: '/?msg=ok&name=' + encodeURIComponent(firstName + ' ' + lastName) });
      res.end();
    } catch (err) {
      const errMsg = encodeURIComponent(err.message || 'Unknown error');
      res.writeHead(302, { Location: '/?msg=err&detail=' + errMsg });
      res.end();
    }
    return;
  }

  // ── GET /table — partial HTML for AJAX table refresh ──
  if (req.url === '/table') {
    try {
      const rows = queryEuropeans();
      const tableRows = rows.map(r =>
        '<tr><td>' + r.FirstName + '</td><td>' + r.LastName + '</td><td>' + r.Flag + ' ' + r.CountryOfOrigin + '</td></tr>'
      ).join('\n');
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(tableRows);
    } catch (err) {
      res.writeHead(500, { 'Content-Type': 'text/plain' });
      res.end(err.message);
    }
    return;
  }

  // ── GET / — HTML viewer + admin form ──
  try {
    const url = new URL(req.url, 'http://localhost');
    const msg = url.searchParams.get('msg');
    const rows = queryEuropeans();
    const tableRows = rows.map(r =>
      '<tr><td>' + r.FirstName + '</td><td>' + r.LastName + '</td><td>' + r.Flag + ' ' + r.CountryOfOrigin + '</td></tr>'
    ).join('\n');

    let banner = '';
    if (msg === 'ok') {
      const name = url.searchParams.get('name') || '';
      banner = '<div class="msg ok">\u2714 Successfully added <b>' + name + '</b> to the database.</div>';
    } else if (msg === 'err') {
      const detail = url.searchParams.get('detail') || 'Unknown error';
      banner = '<div class="msg err">\u2718 Error: ' + detail + '</div>';
    }

    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end('<!DOCTYPE html>\n' +
'<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">\n' +
'<title>US Euro Viewer \u2014 Admin</title>\n' +
'<style>\n' + CSS + '</style></head><body>\n' +
'<div class="wrap">\n' +
banner +
'  <div class="card">\n' +
'    <h1>Famous Europeans</h1>\n' +
'    <p class="sub">3 random selections from the EU database</p>\n' +
'    <table>\n' +
'      <thead><tr><th>First Name</th><th>Last Name</th><th>Country</th></tr></thead>\n' +
'      <tbody id="rows">' + tableRows + '</tbody>\n' +
'    </table>\n' +
'    <div class="timer">\n' +
'      <div class="timer-label">Refreshing in <span id="sec">5</span>s</div>\n' +
'      <div class="timer-bar"><div class="timer-fill" id="bar"></div></div>\n' +
'      <button class="pause-btn" id="pauseBtn">Pause</button>\n' +
'    </div>\n' +
'  </div>\n' +
'  <div class="card">\n' +
'    <h2>Add a Famous European</h2>\n' +
'    <form method="POST" action="/add">\n' +
'      <label for="firstName">First Name</label>\n' +
'      <input type="text" id="firstName" name="firstName" required maxlength="64" placeholder="e.g. Ada">\n' +
'      <label for="lastName">Last Name</label>\n' +
'      <input type="text" id="lastName" name="lastName" required maxlength="64" placeholder="e.g. Lovelace">\n' +
'      <label for="country">Country</label>\n' +
'      <select id="country" name="country" required>\n' +
'        <option value="">\u2014 Select country \u2014</option>\n' +
countryOptions() + '\n' +
'      </select>\n' +
'      <div class="actions" style="margin-top:1rem;">\n' +
'        <button type="submit">Add European</button>\n' +
'      </div>\n' +
'    </form>\n' +
'  </div>\n' +
'</div>\n' +
'<script>\n' +
'let t=5, paused=false;\n' +
'const el=document.getElementById("sec"), bar=document.getElementById("bar"), rows=document.getElementById("rows"), btn=document.getElementById("pauseBtn");\n' +
'btn.onclick=()=>{ paused=!paused; btn.textContent=paused?"Resume":"Pause";\n' +
'  bar.classList.toggle("paused",paused); };\n' +
'setInterval(()=>{\n' +
'  if(paused) return;\n' +
'  t--; el.textContent=t;\n' +
'  if(t<=0){ t=5; bar.style.animation="none"; bar.offsetHeight; bar.style.animation="countdown 5s linear forwards";\n' +
'    fetch("/table").then(r=>r.text()).then(h=>{rows.innerHTML=h;}).catch(()=>{}); }\n' +
'},1000);\n' +
'</script>\n' +
'</body></html>');
  } catch (err) {
    res.writeHead(500, { 'Content-Type': 'text/html' });
    res.end('<h1>Error</h1><pre>' + err.message + '</pre>');
  }
});
server.listen(PORT, () => console.log('US Euro Viewer Admin listening on ' + PORT));
