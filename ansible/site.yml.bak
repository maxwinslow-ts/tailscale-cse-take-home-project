---
# ═══════════════════════════════════════════════════════════════════════
# Sovereign Mesh — Ansible Playbook Scaffolding
#
# Usage:
#   1. terraform apply
#   2. bash ansible/generate-inventory.sh
#   3. cd ansible && ansible-playbook site.yml
#
# Connection: uses custom orbstack connection plugin (no SSH needed).
# All VMs are Ubuntu 22.04 (Jammy) on OrbStack.
# ═══════════════════════════════════════════════════════════════════════

# ── Play 1: EU Database Server (eu-db) ───────────────────────────────
#
# GOAL: MySQL server reachable only on the OrbStack bridge IP,
#       Tailscale installed for SSH management only (no routes).
#
# INSTALL:
#   - mysql-server (apt)
#   - curl (apt, needed for tailscale install script)
#   - tailscale: curl -fsSL https://tailscale.com/install.sh | sh
#
# CONFIGURE:
#   - tailscale up --authkey={{ ts_authkey }} --hostname=eu-db --ssh
#   - Bind MySQL to {{ orb_bridge_ip }} only (not 0.0.0.0):
#       Edit /etc/mysql/mysql.conf.d/mysqld.cnf → bind-address = {{ orb_bridge_ip }}
#       Restart mysql service
#   - Seed a demo database:
#       CREATE DATABASE app;
#       CREATE TABLE app.demo (id INT AUTO_INCREMENT PRIMARY KEY, region VARCHAR(32), message VARCHAR(255));
#       INSERT INTO app.demo (region, message) VALUES ('eu', 'Hello from the EU database');
#       CREATE USER 'app'@'%' IDENTIFIED BY '<password>';
#       GRANT SELECT ON app.* TO 'app'@'%';
#
# NOTE: "Disable SSH" tasks are a no-op — OrbStack VMs don't have sshd.
#       Tailscale SSH becomes the only remote management path.
#
- name: Configure EU Database Server
  hosts: eu-db
  become: true
  tasks:
    - name: Install packages
      apt:
        name: [mysql-server, curl, tcpdump]
        state: present
        update_cache: true

    - name: Install Tailscale
      shell: curl -fsSL https://tailscale.com/install.sh | sh
      args:
        creates: /usr/bin/tailscale

    - name: Join tailnet (SSH management only — no routes)
      command: >-
        tailscale up
        --authkey={{ ts_authkey }}
        --hostname=eu-db
        --ssh
      register: ts_result
      changed_when: ts_result.rc == 0

    - name: Bind MySQL to bridge IP only
      lineinfile:
        path: /etc/mysql/mysql.conf.d/mysqld.cnf
        regexp: '^bind-address'
        line: "bind-address = {{ orb_bridge_ip }}"
      notify: restart mysql

    - name: Restart MySQL now
      meta: flush_handlers

    - name: Seed demo database
      shell: |
        mysql -u root <<'SQL'
        CREATE DATABASE IF NOT EXISTS app;
        USE app;
        CREATE TABLE IF NOT EXISTS demo (
          id INT AUTO_INCREMENT PRIMARY KEY,
          region VARCHAR(32) NOT NULL,
          message VARCHAR(255) NOT NULL
        );
        INSERT INTO demo (region, message)
        SELECT 'eu', 'Hello from the EU database'
        WHERE NOT EXISTS (SELECT 1 FROM demo WHERE region='eu' LIMIT 1);
        CREATE USER IF NOT EXISTS 'app'@'%' IDENTIFIED WITH mysql_native_password BY 'apppass';
        GRANT SELECT ON app.* TO 'app'@'%';
        FLUSH PRIVILEGES;
        SQL

    - name: Seed famous Europeans table
      shell: |
        mysql -u root <<'SQL'
        USE app;
        DROP TABLE IF EXISTS famous_europeans;
        CREATE TABLE famous_europeans (
          id INT AUTO_INCREMENT PRIMARY KEY,
          FirstName VARCHAR(64) NOT NULL,
          LastName VARCHAR(64) NOT NULL,
          CountryOfOrigin VARCHAR(64) NOT NULL,
          Flag VARCHAR(16) NOT NULL
