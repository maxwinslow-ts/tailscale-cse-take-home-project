          ('Ada', 'Lovelace', 'England', '🏴󠁧󠁢󠁥󠁮󠁧󠁿'),
          ('Rosalind', 'Franklin', 'England', '🏴󠁧󠁢󠁥󠁮󠁧󠁿'),
          ('Lise', 'Meitner', 'Austria', '🇦🇹'),
          ('Antoine', 'Lavoisier', 'France', '🇫🇷'),
          ('Werner', 'Heisenberg', 'Germany', '🇩🇪'),
          ('Nils Henrik', 'Abel', 'Norway', '🇳🇴'),
          ('Sofia', 'Kovalevskaya', 'Russia', '🇷🇺');
        SQL

  handlers:
    - name: restart mysql
      service:
        name: mysql
        state: restarted

# ── Play 2: EU Subnet Router (eu-router) ─────────────────────────────
#
# GOAL: Tailscale subnet router that advertises eu-db's bridge IP
#       so the US app can reach MySQL through the Tailscale mesh.
#
# INSTALL:
#   - curl (apt)
#   - tailscale: curl -fsSL https://tailscale.com/install.sh | sh
#
# CONFIGURE:
#   - Enable IP forwarding: sysctl net.ipv4.ip_forward=1
#   - Join tailnet as subnet router:
#       tailscale up --authkey={{ ts_authkey }} \
#         --hostname=eu-router \
#         --advertise-routes={{ eu_db_bridge_ip }}/32 \
#         --accept-routes \
#         --snat-subnet-routes=false \
#         --ssh
#
- name: Configure EU Subnet Router
  hosts: eu-router
  become: true
  tasks:
    - name: Install curl
      apt:
        name: [curl]
        state: present
        update_cache: true

    - name: Enable IP forwarding
      sysctl:
        name: net.ipv4.ip_forward
        value: "1"
        sysctl_set: true
        reload: true

    - name: Install Tailscale
      shell: curl -fsSL https://tailscale.com/install.sh | sh
      args:
        creates: /usr/bin/tailscale

    - name: Join tailnet as subnet router
      command: >
        tailscale up
        --authkey={{ ts_authkey }}
        --hostname=eu-router
        --advertise-routes={{ eu_db_bridge_ip }}/32
        --accept-routes
        --snat-subnet-routes=false
        --ssh
      register: ts_result
      changed_when: ts_result.rc == 0

    - name: Clamp MSS to MTU (per Tailscale site-to-site docs)
      shell: |
        iptables -t mangle -C FORWARD -o tailscale0 -p tcp -m tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu 2>/dev/null || \
        iptables -t mangle -A FORWARD -o tailscale0 -p tcp -m tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu

# ── Play 3: US Application Server (us-app) ───────────────────────────
#
# GOAL: Docker host running a Tailscale container (mesh endpoint)
#       and a Node.js "euroviewer" app that displays Famous Europeans from the EU DB.
#
# INSTALL:
#   - docker.io, docker-compose-v2 (apt)
#
# CONFIGURE:
#   - Write /etc/docker/daemon.json: { "userland-proxy": false }
#     (preserves source IPs through Docker bridge)
#   - Restart docker service
#   - Create /opt/stack/ directory
#   - Write /opt/stack/docker-compose.yaml with two services:
#
#     1. tailscale container (tailscale/tailscale:latest):
#        - TS_AUTHKEY={{ ts_authkey }}
#        - TS_EXTRA_ARGS=--advertise-routes=172.21.0.0/24 --accept-routes --snat-subnet-routes=false --ssh
#        - cap_add: NET_ADMIN, devices: /dev/net/tun
#        - IP: 172.21.0.2 on bridge subnet 172.21.0.0/24
#
#     2. app container (node:18-alpine):
#        - Mounts /opt/stack/server.js
#        - IP: 172.21.0.10
#        - Needs route: ip route add <eu_db_bridge_ip>/32 via 172.21.0.2
#        - Needs route: ip route add 100.64.0.0/10 via 172.21.0.2
#        - Expose port 80:3000
#
#   - Write /opt/stack/server.js:
#        Node.js HTTP server with two endpoints:
#        /       — HTML page with a styled table of 3 random famous Europeans
#        /json   — JSON response with 3 random famous Europeans
#
#   - docker compose -f /opt/stack/docker-compose.yaml up -d
#
- name: Configure US Application Server
  hosts: us-app
  become: true
  tasks:
    - name: Install Docker packages
      apt:
        name: [docker.io, docker-compose-v2]
        state: present
        update_cache: true

    - name: Configure Docker daemon (disable userland-proxy)
      copy:
        dest: /etc/docker/daemon.json
        content: '{ "userland-proxy": false }'
      notify: restart docker

    - name: Ensure Docker is running
      service:
        name: docker
        state: started
        enabled: true

    - name: Flush handlers (restart docker if config changed)
      meta: flush_handlers

    - name: Create stack directory
      file:
        path: /opt/stack
        state: directory

    - name: Write docker-compose.yaml
      copy:
        dest: /opt/stack/docker-compose.yaml
        content: |
          services:
            tailscale:
              image: tailscale/tailscale:latest
              hostname: us-app
              container_name: euroviewer-ts
              cap_add:
                - NET_ADMIN
              devices:
                - /dev/net/tun:/dev/net/tun
              volumes:
                - /var/lib/tailscale:/var/lib/tailscale
              environment:
                - TS_AUTHKEY={{ ts_authkey }}
                - TS_HOSTNAME=us-app
                - TS_USERSPACE=false
                - TS_EXTRA_ARGS=--advertise-routes=172.21.0.0/24 --accept-routes --snat-subnet-routes=false --ssh
              networks:
                mesh:
                  ipv4_address: 172.21.0.2
              restart: always

            app:
              image: node:18-alpine
              container_name: euroviewer
              cap_add:
                - NET_ADMIN
              depends_on:
                - tailscale
              ports:
                - "80:3000"
              networks:
                mesh:
                  ipv4_address: 172.21.0.10
              volumes:
                - /opt/stack/server.js:/app/server.js:ro
              command:
                - sh
                - -c
                - |
                  sleep 5
                  apk add --no-cache iproute2 mysql-client >/dev/null 2>&1
                  ip route add {{ eu_db_bridge_ip }}/32 via 172.21.0.2 2>/dev/null || true
                  ip route add 100.64.0.0/10 via 172.21.0.2 2>/dev/null || true
                  node /app/server.js
              restart: always

            healthcheck:
              image: node:18-alpine
              container_name: healthcheck
              cap_add:
                - NET_ADMIN
              depends_on:
                - tailscale
                - app
              ports:
                - "8080:8080"
              networks:
                mesh:
                  ipv4_address: 172.21.0.20
              volumes:
                - /opt/stack/healthcheck.js:/app/healthcheck.js:ro
              environment:
                - EU_DB_BRIDGE_IP={{ eu_db_bridge_ip }}
              command:
                - sh
                - -c
                - |
                  sleep 8
                  apk add --no-cache iproute2 mysql-client curl >/dev/null 2>&1
                  ip route add {{ eu_db_bridge_ip }}/32 via 172.21.0.2 2>/dev/null || true
                  ip route add 100.64.0.0/10 via 172.21.0.2 2>/dev/null || true
                  node /app/healthcheck.js
              restart: always

          networks:
            mesh:
              driver: bridge
              ipam:
                config:
                  - subnet: 172.21.0.0/24

    - name: Write server.js
      copy:
        dest: /opt/stack/server.js
        content: |
          const http = require('http');
          const { execSync } = require('child_process');
          const PORT = 3000;
          const DB_IP = '{{ eu_db_bridge_ip }}';

          function queryEuropeans() {
            const raw = execSync(
              'mysql -h ' + DB_IP + ' -u app -papppass -D app --skip-ssl --default-character-set=utf8mb4 ' +
              '-e "SELECT FirstName, LastName, Flag, CountryOfOrigin FROM famous_europeans ORDER BY RAND() LIMIT 3" ' +
              '--batch --raw 2>/dev/null',
              { timeout: 10000, encoding: 'utf8' }
            );
            const lines = raw.trim().split('\n');
            const headers = lines[0].split('\t');
            return lines.slice(1).map(l => {
              const v = l.split('\t');
              return Object.fromEntries(headers.map((h, i) => [h, v[i]]));
            });
          }

          const server = http.createServer((req, res) => {
            if (req.url === '/json') {
              try {
                const rows = queryEuropeans();
                res.writeHead(200, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ source: 'eu-db', europeans: rows }));
              } catch (err) {
                res.writeHead(500, { 'Content-Type': 'application/json' });
                res.end(JSON.stringify({ error: err.message }));
              }
              return;
            }

            // Root endpoint — HTML table
            try {
              const rows = queryEuropeans();
              const tableRows = rows.map(r =>
                '<tr><td>' + r.FirstName + '</td><td>' + r.LastName + '</td><td>' + r.Flag + ' ' + r.CountryOfOrigin + '</td></tr>'
              ).join('\n              ');
              res.writeHead(200, { 'Content-Type': 'text/html' });
              res.end('<!DOCTYPE html>\n' +
                '<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">\n' +
                '<title>European Viewer</title>\n' +
                '<style>\n' +
                '  * { margin: 0; padding: 0; box-sizing: border-box; }\n' +
                '  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;\n' +
                '         background: #f0f4f8; display: flex; justify-content: center; align-items: center;\n' +
                '         min-height: 100vh; color: #1a202c; }\n' +
                '  .card { background: #fff; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.08);\n' +
                '          padding: 2rem 2.5rem; max-width: 600px; width: 100%; }\n' +
                '  h1 { font-size: 1.5rem; margin-bottom: .25rem; }\n' +
                '  p.sub { color: #718096; margin-bottom: 1.5rem; font-size: .9rem; }\n' +
                '  table { width: 100%; border-collapse: collapse; }\n' +
                '  th { text-align: left; padding: .75rem 1rem; background: #edf2f7; color: #4a5568;\n' +
                '       font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; }\n' +
                '  td { padding: .75rem 1rem; border-bottom: 1px solid #e2e8f0; }\n' +
                '  tr:last-child td { border-bottom: none; }\n' +
                '  .actions { margin-top: 1.5rem; text-align: center; }\n' +
                '  .actions a { display: inline-block; padding: .5rem 1.25rem; background: #4299e1;\n' +
                '               color: #fff; border-radius: 6px; text-decoration: none; font-size: .9rem;\n' +
                '               margin: 0 .25rem; }\n' +
                '  .actions a:hover { background: #3182ce; }\n' +
                '  .actions a.secondary { background: #e2e8f0; color: #4a5568; }\n' +
                '  .actions a.secondary:hover { background: #cbd5e0; }\n' +
                '</style></head><body>\n' +
                '<div class="card">\n' +
                '  <h1>Famous Europeans</h1>\n' +
                '  <p class="sub">3 random selections from the EU database</p>\n' +
                '  <table>\n' +
                '    <thead><tr><th>First Name</th><th>Last Name</th><th>Country</th></tr></thead>\n' +
                '    <tbody>\n' +
                '      ' + tableRows + '\n' +
                '    </tbody>\n' +
                '  </table>\n' +
                '  <div class="actions">\n' +
                '    <a href="/">Refresh</a>\n' +
                '    <a class="secondary" href="/json">JSON</a>\n' +
                '  </div>\n' +
                '</div>\n' +
                '</body></html>');
            } catch (err) {
              res.writeHead(500, { 'Content-Type': 'text/html' });
              res.end('<h1>Error</h1><pre>' + err.message + '</pre>');
            }
          });
          server.listen(PORT, () => console.log('European Viewer listening on ' + PORT));

    - name: Write healthcheck.js
      copy:
        dest: /opt/stack/healthcheck.js
        content: |
          const http = require('http');
          const { execSync } = require('child_process');
          const PORT = 8080;
          const DB_IP = process.env.EU_DB_BRIDGE_IP;
          const CHECK_INTERVAL = 5000;

          let lastResults = { ts: null, checks: [] };

          function run(cmd, timeout) {
            try {
              return { ok: true, out: execSync(cmd, { timeout: timeout || 8000, encoding: 'utf8' }).trim() };
            } catch (e) {
              return { ok: false, out: (e.stderr || e.message || '').toString().trim() };
            }
          }

          function ping(ip) {
            return run('ping -c 1 -W 3 ' + ip + ' 2>/dev/null', 5000);
          }

          function latency(r) {
            if (!r.ok) return null;
            const m = r.out.match(/time[=<](\d+\.?\d*)/); return m ? m[1] + ' ms' : null;
          }

          function runChecks() {
            const checks = [];

            // 1. Ping euroviewer app container (bridge)
            const p1 = ping('172.21.0.10');
            checks.push({ name: 'Euroviewer App', desc: 'Ping 172.21.0.10 (Docker bridge)',
              pass: p1.ok, detail: p1.ok ? latency(p1) || 'reachable' : 'unreachable' });

            // 2. Ping euroviewer-ts Tailscale sidecar (bridge)
            const p2 = ping('172.21.0.2');
            checks.push({ name: 'Tailscale Sidecar', desc: 'Ping 172.21.0.2 (Docker bridge)',
              pass: p2.ok, detail: p2.ok ? latency(p2) || 'reachable' : 'unreachable' });

            // 3. Ping eu-db bridge IP (through subnet route)
            const p4 = ping(DB_IP);
            checks.push({ name: 'EU Database', desc: 'Ping ' + DB_IP + ' via subnet route',
              pass: p4.ok, detail: p4.ok ? latency(p4) || 'reachable' : 'unreachable' });

            // 5. MySQL query (full data path)
            const mysql = run(
              'mysql -h ' + DB_IP + ' -u app -papppass -D app --skip-ssl --default-character-set=utf8mb4 ' +
              '-e "SELECT COUNT(*) AS cnt FROM famous_europeans" --batch --raw 2>/dev/null'
            );
            const rowCount = mysql.ok ? (mysql.out.split('\n')[1] || '0') : '0';
            checks.push({ name: 'MySQL Query', desc: 'SELECT from eu-db via subnet route',
              pass: mysql.ok && parseInt(rowCount) > 0,
              detail: mysql.ok ? rowCount + ' rows' : 'connection failed' });

            // 6. HTTP /json on euroviewer
            const appJson = run('curl -sf --max-time 5 http://172.21.0.10:3000/json 2>/dev/null');
            let jsonOk = false;
            if (appJson.ok) { try { jsonOk = JSON.parse(appJson.out).source === 'eu-db'; } catch(e) {} }
            checks.push({ name: 'Euroviewer /json', desc: 'HTTP JSON endpoint returns eu-db data',
              pass: jsonOk, detail: jsonOk ? 'OK' : 'no response' });

            // 7. HTTP / on euroviewer
            const appHtml = run('curl -sf --max-time 5 http://172.21.0.10:3000/ 2>/dev/null');
            const htmlOk = appHtml.ok && /Famous Europeans/.test(appHtml.out);
            checks.push({ name: 'Euroviewer HTML', desc: 'Root endpoint renders table',
              pass: htmlOk, detail: htmlOk ? 'OK' : 'no response' });

            const passed = checks.filter(c => c.pass).length;
            lastResults = { ts: new Date().toISOString(), checks, passed, total: checks.length };
          }

          runChecks();
          setInterval(runChecks, CHECK_INTERVAL);

          const server = http.createServer((req, res) => {
            if (req.url === '/api') {
              res.writeHead(200, { 'Content-Type': 'application/json' });
              res.end(JSON.stringify(lastResults));
              return;
            }

            const r = lastResults;
            const allGreen = r.passed === r.total;
            const checksHtml = (r.checks || []).map(c =>
              '<tr class="' + (c.pass ? 'pass' : 'fail') + '">' +
              '<td class="status">' + (c.pass ? '\u2705' : '\u274C') + '</td>' +
              '<td><strong>' + c.name + '</strong><br><span class="desc">' + c.desc + '</span></td>' +
              '<td class="detail">' + c.detail + '</td></tr>'
            ).join('\n');

            res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
            res.end('<!DOCTYPE html>\n' +
              '<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">\n' +
              '<title>Health Check</title>\n' +
              '<meta http-equiv="refresh" content="5">\n' +
              '<style>\n' +
              '  * { margin:0; padding:0; box-sizing:border-box; }\n' +
              '  body { font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;\n' +
              '         background:#0f172a; color:#e2e8f0; min-height:100vh; padding:2rem; }\n' +
              '  .wrap { max-width:700px; margin:0 auto; }\n' +
              '  .header { display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; }\n' +
              '  .header .dot { width:16px; height:16px; border-radius:50%;\n' +
              '                 background:' + (allGreen ? '#22c55e' : '#ef4444') + ';\n' +
              '                 box-shadow:0 0 8px ' + (allGreen ? '#22c55e88' : '#ef444488') + '; }\n' +
              '  h1 { font-size:1.25rem; font-weight:600; }\n' +
              '  .meta { color:#64748b; font-size:.8rem; margin-bottom:1.5rem; display:flex; align-items:center; gap:.75rem; }\n' +
              '  .timer-bar { flex:1; max-width:120px; height:4px; background:#1e293b; border-radius:2px; overflow:hidden; }\n' +
              '  .timer-fill { height:100%; background:' + (allGreen ? '#22c55e' : '#f59e0b') + ';\n' +
              '                border-radius:2px; animation:countdown 5s linear forwards; }\n' +
              '  @keyframes countdown { from { width:100%; } to { width:0%; } }\n' +
              '  .score { font-size:.9rem; margin-bottom:1rem;\n' +
              '           color:' + (allGreen ? '#22c55e' : '#f59e0b') + '; font-weight:600; }\n' +
              '  table { width:100%; border-collapse:collapse; }\n' +
              '  tr { border-bottom:1px solid #1e293b; }\n' +
              '  td { padding:.75rem .5rem; vertical-align:top; }\n' +
              '  .status { width:2rem; text-align:center; font-size:1.1rem; }\n' +
              '  .desc { color:#64748b; font-size:.8rem; }\n' +
              '  .detail { color:#94a3b8; font-size:.85rem; text-align:right; }\n' +
              '  tr.fail { background:#1c1117; }\n' +
              '  tr.pass { background:#0f1a12; }\n' +
              '  .footer { margin-top:1.5rem; text-align:center; font-size:.75rem; color:#475569; }\n' +
              '  .footer a { color:#64748b; }\n' +
              '</style></head><body>\n' +
              '<div class="wrap">\n' +
              '  <div class="header"><div class="dot"></div><h1>Sovereign Mesh \\u2014 Health Check</h1></div>\n' +
              '  <div class="meta">Last check: ' + (r.ts || 'pending') + ' <div class="timer-bar"><div class="timer-fill"></div></div> <span id="cd">5</span>s</div>\n' +
              '  <div class="score">' + (r.passed || 0) + ' / ' + (r.total || 0) + ' checks passing</div>\n' +
              '  <table>' + checksHtml + '</table>\n' +
              '  <div class="footer"><a href="/api">JSON API</a> \\u00B7 <a href="http://' + req.headers.host.replace(':8080', '') + '/">Euroviewer</a></div>\n' +
              '</div>\n' +
              '<script>let s=5;const e=document.getElementById("cd");const t=setInterval(()=>{s--;if(s<0)s=0;e.textContent=s;},1000);</script>\n' +
              '</body></html>');
          });
          server.listen(PORT, () => console.log('Health check dashboard on ' + PORT));

    - name: Start Docker Compose stack
      command: docker compose -f /opt/stack/docker-compose.yaml up -d
      args:
        chdir: /opt/stack

  handlers:
    - name: restart docker
      service:
        name: docker
        state: restarted

# ── Play 4: Return Routes on eu-db ───────────────────────────────────
#
# GOAL: Per Tailscale site-to-site docs (Step 5), each subnet device
#       needs routes back through its local subnet router for:
#       - 100.64.0.0/10 (Tailscale CGNAT range — source IPs from mesh)
#       - 172.21.0.0/24 (US Docker subnet)
#
- name: Configure EU DB return routes
  hosts: eu-db
  become: true
  tasks:
    - name: Add return route for Tailscale CGNAT via eu-router
      command: ip route add 100.64.0.0/10 via {{ hostvars['eu-router']['orb_bridge_ip'] }}
      register: cgnat_route
      changed_when: cgnat_route.rc == 0
      failed_when: cgnat_route.rc != 0 and 'File exists' not in cgnat_route.stderr

    - name: Add return route for US Docker subnet via eu-router
      command: ip route add 172.21.0.0/24 via {{ hostvars['eu-router']['orb_bridge_ip'] }}
      register: docker_route
      changed_when: docker_route.rc == 0
      failed_when: docker_route.rc != 0 and 'File exists' not in docker_route.stderr
