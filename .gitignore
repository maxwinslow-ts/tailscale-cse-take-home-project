# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variables (may contain secrets)
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Plan files
*.tfplan
out.plan

# Generated files (contain secrets)
generated/

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db
